{
  "name": "finora",
  "version": "1.0.0",
  "description": "Smart Digital Wallet",
  "main": "server/server.js",
  "scripts": {
    "install-all": "npm install && npm install --prefix server && npm install --prefix client",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "npm run seed --prefix server",
    "build-server": "npm install --prefix server",
    "build-client": "npm install --prefix client && npm run build --prefix client",
    "start-server": "node server/server.js",
    "start-client": "npm run preview --prefix client",
    "build": "npm run build-server && npm run build-client",
    "start": "npm run start-server"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
